fiszka.java
package com.example.kreatorfiszekiquiz;

public class fiszka {
    String pytanie;
    String odpowiedz;
    String definicja;
    String pojecie;

    public  fiszka(String pytanie, String odpowiedz, String definicja, String pojecie){
        this.pytanie = pytanie;
        this.odpowiedz = odpowiedz;
        this.definicja = definicja;
        this.pojecie = pojecie;
    }

    public String getPytanie(){
        return pytanie;
    }

    public String getOdpowiedz(){
        return  odpowiedz;
    }

    public String getDefinicja(){
        return definicja;
    }
    public String getPojecie(){
        return  pojecie;
    }

    @Override
    public String toString() {
        return "Pytanie: " + pytanie + " | Odp: " + odpowiedz;
    }
}

