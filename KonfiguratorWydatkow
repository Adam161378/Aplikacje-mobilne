package com.example.menedzerwydatkow;

import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.Button;
import android.widget.TextView;

import androidx.annotation.NonNull;
import androidx.recyclerview.widget.RecyclerView;

import java.util.ArrayList;
import java.util.Locale;

public class WydatekAdapter extends RecyclerView.Adapter<WydatekAdapter.VH> {

    private final ArrayList<Wydatek> lista;
    private final OnWydatekActionListener listener;

    public interface OnWydatekActionListener {
        void onDeleteClicked(int position);
        void onItemClicked(Wydatek wydatek);
    }

    public WydatekAdapter(ArrayList<Wydatek> lista, OnWydatekActionListener listener) {
        this.lista = lista;
        this.listener = listener;
    }

    @NonNull
    @Override
    public VH onCreateViewHolder(@NonNull ViewGroup parent, int viewType) {
        View v = LayoutInflater.from(parent.getContext())
                .inflate(R.layout.item_wydatek, parent, false);
        return new VH(v);
    }

    @Override
    public void onBindViewHolder(@NonNull VH h, int pos) {

        Wydatek w = lista.get(pos);

        h.nazwa.setText(w.getNazwa());
        h.kategoria.setText(w.getKategoria());
        h.kwota.setText(String.format(Locale.getDefault(), "%.2f zł", w.getKwota()));

        h.itemView.setOnClickListener(v ->
                listener.onItemClicked(w));

        h.usun.setOnClickListener(v ->
                listener.onDeleteClicked(h.getAdapterPosition()));
    }

    @Override
    public int getItemCount() {
        return lista.size();
    }

    public static class VH extends RecyclerView.ViewHolder {

        TextView nazwa, kategoria, kwota;
        Button usun;

        public VH(@NonNull View itemView) {
            super(itemView);

            nazwa = itemView.findViewById(R.id.tekstNazwa);
            kategoria = itemView.findViewById(R.id.tekstKategoria);
            kwota = itemView.findViewById(R.id.tekstKwota);
            usun = itemView.findViewById(R.id.przyciskUsun);
        }
    }
}
