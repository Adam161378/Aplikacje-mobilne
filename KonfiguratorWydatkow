package com.example.menedzerwydatkow;

import android.os.Bundle;
import android.view.View;
import android.widget.*;

import androidx.annotation.NonNull;
import androidx.appcompat.app.AppCompatActivity;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import java.util.ArrayList;
import java.util.Locale;

public class MainActivity extends AppCompatActivity
        implements View.OnClickListener, WydatekAdapter.OnWydatekActionListener {

    private static final String KEY_LISTA = "lista_wydatkow";

    private ArrayList<Wydatek> lista = new ArrayList<>();

    private EditText nazwa, kwota;
    private Spinner spinner;

    private TextView liczbaTxt, sumaTxt, najdrozszyTxt;

    private RecyclerView recycler;
    private WydatekAdapter adapter;

    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);
        setContentView(R.layout.activity_main);

        // --- UI ---
        nazwa = findViewById(R.id.poleNazwaWydatku);
        kwota = findViewById(R.id.poleKwotaWydatku);
        spinner = findViewById(R.id.spinnerKategoria);

        liczbaTxt = findViewById(R.id.tekstLiczbaWydatkow);
        sumaTxt = findViewById(R.id.tekstSumaWydatkow);
        najdrozszyTxt = findViewById(R.id.tekstNajdrozszy);

        recycler = findViewById(R.id.listaWydatkow);

        Button btn = findViewById(R.id.przyciskZapisz);

        // --- RESTORE STATE ---
        if (savedInstanceState != null) {
            lista = (ArrayList<Wydatek>) savedInstanceState.getSerializable(KEY_LISTA);
            if (lista == null) lista = new ArrayList<>();
        }

        // --- ADAPTER ---
        adapter = new WydatekAdapter(lista, this);
        recycler.setLayoutManager(new LinearLayoutManager(this));
        recycler.setAdapter(adapter);

        btn.setOnClickListener(this);

        odswiezPodsumowanie();
    }

    @Override
    public void onClick(View v) {

        String n = nazwa.getText().toString().trim();
        String k = kwota.getText().toString().trim();
        String kat = spinner.getSelectedItem().toString();

        if (n.isEmpty() || k.isEmpty()) {
            Toast.makeText(this, "Uzupełnij pola", Toast.LENGTH_SHORT).show();
            return;
        }

        double kw;
        try {
            kw = Double.parseDouble(k);
        } catch (Exception e) {
            Toast.makeText(this, "Zła kwota", Toast.LENGTH_SHORT).show();
            return;
        }

        lista.add(new Wydatek(n, kw, kat));
        adapter.notifyItemInserted(lista.size() - 1);

        wyczysc();
        odswiezPodsumowanie();

        recycler.smoothScrollToPosition(lista.size() - 1);
    }

    @Override
    public void onDeleteClicked(int position) {
        if (position < 0 || position >= lista.size()) return;

        lista.remove(position);
        adapter.notifyItemRemoved(position);

        odswiezPodsumowanie();
    }

    @Override
    public void onItemClicked(Wydatek w) {
        Toast.makeText(this, w.getNazwa(), Toast.LENGTH_SHORT).show();
    }

    private void odswiezPodsumowanie() {

        double suma = 0;
        Wydatek najdrozszy = null;

        for (Wydatek w : lista) {
            suma += w.getKwota();

            if (najdrozszy == null || w.getKwota() > najdrozszy.getKwota()) {
                najdrozszy = w;
            }
        }

        liczbaTxt.setText("Liczba: " + lista.size());
        sumaTxt.setText("Suma: " + String.format(Locale.getDefault(), "%.2f zł", suma));

        if (najdrozszy == null) {
            najdrozszyTxt.setText("Najdroższy: -");
            najdrozszyTxt.setVisibility(View.GONE);
        } else {
            najdrozszyTxt.setVisibility(View.VISIBLE);
            najdrozszyTxt.setText(
                    "Najdroższy: " + najdrozszy.getNazwa()
                            + " (" + najdrozszy.getKwota() + " zł)"
            );
        }
    }

    private void wyczysc() {
        nazwa.setText("");
        kwota.setText("");
        spinner.setSelection(0);
    }

    @Override
    protected void onSaveInstanceState(@NonNull Bundle outState) {
        super.onSaveInstanceState(outState);

        outState.putSerializable(KEY_LISTA, lista);
    }
}
